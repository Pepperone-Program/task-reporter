NODE_ENV=development
PORT=3000

# Trello
TRELLO_API_KEY=
TRELLO_API_SECRET=
TRELLO_TOKEN=
TRELLO_BOARD_ID=
TRELLO_DONE_LIST_NAMES=Done,Feito,Concluido,Concluida,Concluído,Concluída

# Obrigatorio para notificacao imediata via webhook.
# Exemplo: https://seu-dominio.com/webhooks/trello
TRELLO_CALLBACK_URL=
TRELLO_WEBHOOK_DESCRIPTION=Webhook Task Reporter

# W-API / WhatsApp
W_API_BASE_URL=https://api.w-api.app/v1
W_API_INSTANCE_ID=
W_API_TOKEN=
W_API_KEY=
W_API_GROUP_IDS=12036322036366919144@g.us,12036300000000000000@g.us
W_API_DELAY_MESSAGE=1

# Ajuste somente se a W-API alterar os caminhos.
# Placeholders aceitos: {instanceId}, {groupId}
W_API_GROUPS_PATH=/instances/{instanceId}/groups
W_API_SEND_TEXT_PATH=/message/send-text

# Fila de envio
QUEUE_CONCURRENCY=1
QUEUE_RETRIES=3
QUEUE_RETRY_DELAY_MS=1500
