NODE_ENV=development
PORT=3000

# Trello
TRELLO_API_KEY=
TRELLO_API_SECRET=
TRELLO_TOKEN=
TRELLO_BOARD_ID=
TRELLO_DONE_LIST_NAMES=Done,Feito,Concluido,Concluida,Concluído,Concluída

# Obrigatorio para notificacao imediata via webhook.
# Exemplo: https://seu-dominio.com/webhooks/trello
TRELLO_CALLBACK_URL=
TRELLO_WEBHOOK_DESCRIPTION=Webhook Task Reporter

# Wasender / WhatsApp
WASENDER_BASE_URL=https://www.wasenderapi.com
WASENDER_ACCESS_TOKEN=
WASENDER_GROUP_IDS=12036322036366919144@g.us,12036300000000000000@g.us

# Ajuste somente se a Wasender alterar os caminhos.
WASENDER_GROUPS_PATH=/api/groups
WASENDER_SEND_TEXT_PATH=/api/send-message

# Fila de envio
QUEUE_CONCURRENCY=1
QUEUE_RETRIES=3
QUEUE_RETRY_DELAY_MS=1500
